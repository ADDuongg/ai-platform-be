# Application
NODE_ENV=development
APP_NAME=ai-platform-be
APP_VERSION=1.0.0
APP_PORT=3000
APP_URL=http://localhost:3000
API_PREFIX=api
API_VERSION=1

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=ai_platform
DB_PASSWORD=ai_platform_secret
DB_DATABASE=ai_platform
DB_SCHEMA=public
DB_SSL=false
DB_LOGGING=true
DB_SYNCHRONIZE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=ai-platform:

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string-at-least-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Auth
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAME_SITE=lax
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_WINDOW_SECONDS=900

# Bootstrap Super Admin (optional — used by seed script)
BOOTSTRAP_ADMIN_EMAIL=admin@ai-platform.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# Throttler
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=debug

# Agent runner mode (process default; seeded agents pin config.provider=ollama):
#   stub      — deterministic fixtures (default, CI)
#   ollama    — live local LLM (recommended for kids-fashion-research-to-image)
#   openai    — OpenAI Chat Completions
#   anthropic — Anthropic Messages API
#   gemini    — Google Gemini
# Image pixels: tool image-generation + FLUX_API_KEY (not AGENT_RUNNER).
AGENT_RUNNER=ollama

# Shared live LLM timeout (fallback: OLLAMA_TIMEOUT_MS)
LLM_TIMEOUT_MS=120000

# Ollama (default / AGENT_RUNNER=ollama / agent config.provider=ollama)
# Live runner passes Agent outputSchema as Ollama format:<json-schema> when non-trivial.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=120000

# OpenAI (AGENT_RUNNER=openai or agent config.provider=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic (AGENT_RUNNER=anthropic or agent config.provider=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Gemini (reserved — placeholder provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Tool runtime (015):
#   stub — no live tool HTTP (default, CI)
#   live — free/local adapters when AGENT_RUNNER is also live
TOOL_RUNTIME=stub
TOOL_STORAGE_ROOT=.data/tool-storage
TOOL_RESULT_MAX_BYTES=262144

# Execution artifacts (021): local blob store (S3 later via ARTIFACT_STORAGE=s3)
ARTIFACT_STORAGE=local
ARTIFACT_STORAGE_ROOT=.data/execution-artifacts

# Flux / BFL image-generation (provider=flux on tool config; requires TOOL_RUNTIME=live)
FLUX_API_KEY=
# BFL_API_KEY=          # alias accepted if FLUX_API_KEY unset
FLUX_BASE_URL=https://api.bfl.ai
FLUX_ENDPOINT_PATH=/v1/flux-2-pro
# FLUX_POLL_INTERVAL_MS=500

# SerpAPI web-search (022 — primary when set; DuckDuckGo fallback)
SERPAPI_API_KEY=
# SERPAPI_BASE_URL=https://serpapi.com
TAVILY_API_KEY=
# TAVILY_BASE_URL=https://api.tavily.com

# Future paid tool providers (commented — not required):
# Google Custom Search (web-search alternate)
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=
# Browserless (web-browser)
# BROWSERLESS_URL=
# BROWSERLESS_TOKEN=
# AWS S3 (object-storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=
