# Application
NODE_ENV=production
APP_NAME=ai-platform-be
APP_VERSION=1.0.0
APP_PORT=3000
APP_URL=https://api.example.com
API_PREFIX=api
API_VERSION=1

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=ai_platform
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_DATABASE=ai_platform
DB_SCHEMA=public
DB_SSL=true
DB_LOGGING=false
DB_SYNCHRONIZE=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0
REDIS_KEY_PREFIX=ai-platform:

# JWT
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_64
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Throttler
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# CORS
CORS_ORIGINS=https://app.example.com

# Logging
LOG_LEVEL=info

# Agent runner / LLM providers
AGENT_RUNNER=stub
LLM_TIMEOUT_MS=120000
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
TOOL_RUNTIME=stub
FLUX_API_KEY=
FLUX_BASE_URL=https://api.bfl.ai
FLUX_ENDPOINT_PATH=/v1/flux-2-pro
