# Application
NODE_ENV=development
APP_NAME=ai-platform-be
APP_VERSION=1.0.0
APP_PORT=3000
APP_URL=http://localhost:3000
API_PREFIX=api
API_VERSION=1

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=ai_platform
DB_PASSWORD=ai_platform_secret
DB_DATABASE=ai_platform
DB_SCHEMA=public
DB_SSL=false
DB_LOGGING=true
DB_SYNCHRONIZE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=ai-platform:

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-characters-long
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Bootstrap super_admin (seed)
BOOTSTRAP_ADMIN_EMAIL=admin@ai-platform.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# Throttler
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=debug

# Agent runner (stub for local CI-safe default; override to ollama|openai|anthropic for live)
AGENT_RUNNER=ollama
LLM_TIMEOUT_MS=120000
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=120000
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
TOOL_RUNTIME=live
FLUX_API_KEY=
FLUX_BASE_URL=https://api.bfl.ai
FLUX_ENDPOINT_PATH=/v1/flux-2-pro
